# vergissmeinnicht — Configuration
#
# Copy this file to config.env and fill in your values.
# config.env is gitignored.

# ──────────────────────────────────────────
# Matrix Notifications
# ──────────────────────────────────────────

MATRIX_HOMESERVER="https://matrix.example.com"
MATRIX_TOKEN="syt_your_access_token_here"

# Rooms to send context reset stats
# Format: "!room_id:server|friendly_name"
MATRIX_ROOMS=(
    "!abc123def:matrix.example.com|planning"
    "!ghi456jkl:matrix.example.com|engineering"
)

# Which room gets the long-format context reset
PLANNING_ROOM="planning"

# ──────────────────────────────────────────
# GPU Inference
# ──────────────────────────────────────────

INFERENCE_URL="http://localhost:8000"
INFERENCE_MODEL="your-model-name"

# ──────────────────────────────────────────
# Agents
# ──────────────────────────────────────────

# Space-separated list of agent names for memory sync
AGENT_LIST="agent1 agent2 agent3"

# ──────────────────────────────────────────
# Paths
# ──────────────────────────────────────────

LOG_DIR="/var/log/vergissmeinnicht"
SUMMARY_DIR="/path/to/daily-summaries"

# ──────────────────────────────────────────
# Commands (customize for your orchestration system)
# ──────────────────────────────────────────

# Warmup command — prime the GPU before real work
WARMUP_CMD="curl -sf ${INFERENCE_URL}/v1/chat/completions \
  -H 'Content-Type: application/json' \
  -d '{\"model\":\"${INFERENCE_MODEL}\",\"messages\":[{\"role\":\"user\",\"content\":\"System check: current date and time?\"}],\"max_tokens\":50}'"

# Daily summary command — create yesterday's summary
# Replace with your agent orchestration command
SUMMARY_CMD="echo 'Replace with: openclaw cron trigger daily-summary'"

# Morning briefing command
BRIEFING_CMD="echo 'Replace with: openclaw cron trigger morning-briefing'"

# Memory sync command (called once per agent, $agent variable available)
MEMORY_SYNC_CMD="echo 'Replace with: openclaw sessions send --agent \$agent --message sync'"

# Alert command (on pipeline failure)
ALERT_CMD="./scripts/notify.sh -m '⚠️ Morning pipeline failed' --room '!monitoring:matrix.example.com'"
