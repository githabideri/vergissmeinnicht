# vergissmeinnicht — Configuration
#
# Copy this file to config.env and fill in your values.
# config.env is gitignored.

# ──────────────────────────────────────────
# Matrix Notifications
# ──────────────────────────────────────────

# Homeserver URL (used for direct API calls via curl)
MATRIX_HOMESERVER="https://matrix.example.com"

# Access token for the notification bot user
MATRIX_TOKEN="syt_your_access_token_here"

# Rooms to send context reset stats
# Format: "!room_id:server|friendly_name"
MATRIX_ROOMS=(
    "!abc123def:matrix.example.com|planning"
    "!ghi456jkl:matrix.example.com|engineering"
)

# Which room gets the long-format context reset (with per-room breakdown)
PLANNING_ROOM="planning"

# Room for pipeline failure alerts
ALERT_ROOM="!abc123def:matrix.example.com"

# ──────────────────────────────────────────
# GPU Inference (optional — for warmup ping)
# ──────────────────────────────────────────

# vLLM / ollama / any OpenAI-compatible endpoint
INFERENCE_URL="http://localhost:8000"
INFERENCE_MODEL="your-model-name"

# ──────────────────────────────────────────
# Agent Orchestration
# ──────────────────────────────────────────

# Space-separated list of agent names
# These agents will: write per-agent summaries, get memory synced
AGENT_LIST="planning labmaster schreiber heimsucher"

# ──────────────────────────────────────────
# Paths
# ──────────────────────────────────────────

# Pipeline logs (one file per day: morning-pipeline-YYYY-MM-DD.log)
LOG_DIR="/var/log/vergissmeinnicht"

# Where shared daily summaries are written (memory/YYYY-MM-DD.md)
SUMMARY_DIR="/path/to/daily-summaries"

# Base directory for agent workspaces (contains agents/<name>/memory/)
AGENT_MEMORY_DIR="/path/to/agents"

# ──────────────────────────────────────────
# Timeouts (seconds)
# ──────────────────────────────────────────

WARMUP_TIMEOUT=120          # GPU warmup ping
AGENT_SUMMARY_TIMEOUT=180   # Per-agent note writing
DAILY_SUMMARY_TIMEOUT=600   # Shared summary aggregation
BRIEFING_TIMEOUT=300        # Morning briefing generation
MEMORY_SYNC_TIMEOUT=60      # Memory search index sync

# ──────────────────────────────────────────
# Commands
#
# These define HOW each phase talks to your agent orchestration system.
# The examples below use OpenClaw CLI, but you can replace with any tool
# that can send a message to an agent and wait for a response.
#
# Design decision: We use direct agent invocation ("sessions send")
# rather than creating temporary cron jobs. This keeps things ephemeral —
# no persistent job cleanup needed. See docs/design-decisions.md §2.
# ──────────────────────────────────────────

# --- Warmup ---
# Primes GPU inference (CUDAGraph compilation + prefix cache).
# A simple prompt that forces model loading without real work.
WARMUP_CMD="curl -sf ${INFERENCE_URL}/v1/chat/completions \
  -H 'Content-Type: application/json' \
  -d '{\"model\":\"${INFERENCE_MODEL}\",\"messages\":[{\"role\":\"user\",\"content\":\"System check: current date?\"}],\"max_tokens\":50}'"

# --- Per-Agent Summary ---
# THE CORE: Each agent summarizes its own sessions into a daily note.
# Variable $agent is set by the orchestrator (current agent name).
# Variable $DATE is set to today's date (YYYY-MM-DD).
#
# The command should:
#   1. Read session history for $agent (since last context reset)
#   2. Summarize into a concise daily note (100-400 words)
#   3. Write to agents/$agent/memory/YYYY-MM-DD.md
#   4. Skip if that file already exists (no overwrites)
#
# Example for OpenClaw:
AGENT_SUMMARY_CMD="cd /opt/openclaw && node openclaw.mjs agent \
  --agent \$agent \
  --message 'Write your daily memory note. Summarize yesterday into agents/\$agent/memory/\${DATE}.md' \
  --timeout ${AGENT_SUMMARY_TIMEOUT}"

# --- Daily Summary ---
# Aggregates all per-agent notes into a single shared overview.
# Reads: agents/*/memory/YYYY-MM-DD.md
# Writes: memory/YYYY-MM-DD.md
SUMMARY_CMD="cd /opt/openclaw && node openclaw.mjs agent \
  --agent planning \
  --message 'Create shared daily summary from all agent notes for today.' \
  --timeout ${DAILY_SUMMARY_TIMEOUT}"

# --- Morning Briefing ---
# Generates daily briefing with weather, system health, pending tasks.
# Reads the shared summary + system metrics.
# Sends to the team planning channel.
BRIEFING_CMD="cd /opt/openclaw && node openclaw.mjs agent \
  --agent planning \
  --message 'Run the morning briefing.' \
  --timeout ${BRIEFING_TIMEOUT}"

# --- Memory Sync ---
# Triggers memory search index update so agents find new daily notes.
# Called once per agent ($agent variable available).
MEMORY_SYNC_CMD="cd /opt/openclaw && node openclaw.mjs agent \
  --agent \$agent \
  --message 'memory_search(\"daily sync\")' \
  --timeout ${MEMORY_SYNC_TIMEOUT}"

# --- Alerts ---
# Called when the pipeline completes with errors (STATUS=degraded).
# Sends a short notice to the alert room.
ALERT_CMD="./scripts/notify.sh --notice -m '⚠️ Morning pipeline degraded' --room '${ALERT_ROOM}'"
