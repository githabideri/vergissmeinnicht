# Local deployment config for Schreiber / clawdbot
# gitignored on purpose
# repo-native scripts read their deployment-specific values from here

WORKSPACE="/var/lib/clawdbot/workspace"
AGENT_DIR="${WORKSPACE}/agents"
SUMMARY_DIR="${WORKSPACE}/memory"
BRIEFING_DIR="${SUMMARY_DIR}/briefings"
LOG_DIR="${WORKSPACE}/logs/crons"
OC_DIR="/opt/openclaw"
OC_HOME="/var/lib/clawdbot/.openclaw"

# INFERENCE_BACKEND: vLLM (preferred) or llama.cpp (fallback)
# vLLM: http://<vllm-host>:8000
# llama.cpp: http://<llama-cpp-host>:8081
INFERENCE_URL="http://<llama-cpp-host>:8081"
INFERENCE_MODEL="<model-name-or-path>"
SUMMARY_AGENT="localbot-planning"

# llama.cpp: dual server setup
# Port 8080: smaller model (e.g., 27B)
# Port 8081: larger model (e.g., 35B-A3B)
# GPU Server läuft ab 07:00 → Pipeline 07:00-08:30 (~90 min total)

# 7 agents (jeden Tag)
# planning excluded from Phase 1 - uses its own cron to create daily summary
# pipeline reads planning's note in Phase 2 (shared summary) like any other agent
AGENTS=(felix labmaster schreiber heimsucher ocr mox vogelhauswart)

# Batch Size: 1 (sequentiell, kein true Parallel)
SUMMARY_BATCH_SIZE=1

declare -A AGENT_WORKSPACE=(
  [felix]="${WORKSPACE}/agents/felix"
  [labmaster]="${WORKSPACE}/agents/labmaster"
  [schreiber]="${WORKSPACE}/agents/schreiber"
  [heimsucher]="${WORKSPACE}/agents/heimsucher"
  [ocr]="${WORKSPACE}/agents/ocr"
  [mox]="${WORKSPACE}/agents-ct339/mox"
  [vogelhauswart]="${WORKSPACE}/agents-ct339/vogelhauswart"
)

# llama.cpp Timeouts (sequentiell, single server, concurrent sessions possible)
# 8 agents × ~15-30 min + Shared Summary + Briefing = ~60-120 min total

# WARMUP: 10 min (model loading + prefix cache priming)
WARMUP_TIMEOUT=600

# AGENT_SUMMARY: 30 min × 8 agents = 240 min total (max)
# Many agents finish faster (no timeout), so total ~2-2.5h
AGENT_SUMMARY_TIMEOUT=1800

# DAILY_SUMMARY: 15 min (aggregiert alle agent notes)
DAILY_SUMMARY_TIMEOUT=900

# BRIEFING: 15 min (liest summary + agent notes)
BRIEFING_TIMEOUT=900

# MEMORY_SYNC: 5 min (optional, disabled currently)
MEMORY_SYNC_TIMEOUT=300

MATRIX_HOMESERVER="https://matrixbot.home.macl.at"
if [ -f "/var/lib/clawdbot/.matrix-commander/servicebot.env" ]; then
  # shellcheck source=/dev/null
  . "/var/lib/clawdbot/.matrix-commander/servicebot.env"
fi
MATRIX_TOKEN="${MATRIX_SERVICEBOT_TOKEN:-}"
MATRIX_ROOMS=(
  "!fdTdAifpvAoIloHzXI:matrixbot.home.macl.at|planning"
  "!MIxzotgFOzbCYYTDGH:matrixbot.home.macl.at|llmlab"
  "!VppnqTxWZkpYILXnzj:matrixbot.home.macl.at|llmlab-control"
  "!FneTkrnmysfSRttkta:matrixbot.home.macl.at|heimsucher"
  "!IxCGxNYrWeukHafCsb:matrixbot.home.macl.at|ocr"
)
PLANNING_ROOM="planning"
ALERT_ROOM="!gqZyMsaqoAPESLkJDz:matrixbot.home.macl.at"
ALERT_CMD="/var/lib/clawdbot/.local/bin/mc-servicebot --notice -m \"⚠️ Morning pipeline \$DATE: \$FINAL_STATUS — \$PHASES\" --room \"$ALERT_ROOM\""

# --- Planning / general briefing ---
PLANNING_BRIEFING_AGENT="planning"
PLANNING_BRIEFING_ROOM_ID="!fdTdAifpvAoIloHzXI:matrixbot.home.macl.at"
PLANNING_BRIEFING_SCOPE_LABEL="planning / general"
PLANNING_BRIEFING_ARCHIVE_DIR="${WORKSPACE}/agents/planning/memory/briefings"
PLANNING_BRIEFING_FOCUS="- general daily overview and reminders\n- broad operational awareness\n- planning-specific follow-ups worth surfacing this morning\n- compact quiet-success rollup for relevant general cron jobs"

# --- Labmaster / llmlab-control briefing ---
LABMASTER_BRIEFING_AGENT="labmaster"
LABMASTER_BRIEFING_ROOM_ID="!VppnqTxWZkpYILXnzj:matrixbot.home.macl.at"
LABMASTER_BRIEFING_SCOPE_LABEL="labmaster / llmlab-control"
LABMASTER_BRIEFING_ARCHIVE_DIR="${WORKSPACE}/agents/labmaster/memory/briefings"
LABMASTER_BRIEFING_FOCUS="- llmlab and local LLM work\n- model scout and model inventory\n- LMCache / vLLM / llama.cpp watch items\n- wgpx15 / GPU / localbot-ctl / pipeline status\n- important active investigations or findings"

# --- Schreiber briefing ---
SCHREIBER_BRIEFING_AGENT="schreiber"
SCHREIBER_BRIEFING_ROOM_ID="!gqZyMsaqoAPESLkJDz:matrixbot.home.macl.at"
SCHREIBER_BRIEFING_SCOPE_LABEL="schreiber"
SCHREIBER_BRIEFING_ARCHIVE_DIR="${WORKSPACE}/agents/schreiber/memory/briefings"
SCHREIBER_BRIEFING_FOCUS="- publishing pipeline and writing work\n- knowledge management and note infrastructure\n- vergissmeinnicht pipeline changes and operational status\n- content/project movement worth surfacing this morning"

# --- Heimsucher briefing ---
HEIMSUCHER_BRIEFING_AGENT="heimsucher"
HEIMSUCHER_BRIEFING_ROOM_ID="!FneTkrnmysfSRttkta:matrixbot.home.macl.at"
HEIMSUCHER_BRIEFING_SCOPE_LABEL="heimsucher"
HEIMSUCHER_BRIEFING_ARCHIVE_DIR="${WORKSPACE}/agents/heimsucher/memory/briefings"
HEIMSUCHER_BRIEFING_FOCUS="- apartment search status and new matches\n- scrape/report pipeline status\n- blockers, missing data, or follow-up actions that matter this morning\n- brief quiet-success rollup only when relevant"
